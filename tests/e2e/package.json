{
  "name": "wayfinder-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright E2E tests for Wayfinder (lives inside the wayfinder repo at tests/e2e/)",
  "scripts": {
    "test": "playwright test --config playwright.config.ts",
    "test:smoke": "playwright test --config playwright.config.ts smoke.spec.ts",
    "test:flows": "playwright test --config playwright.config.ts flows.spec.ts",
    "test:chat": "playwright test --config playwright.config.ts chat.spec.ts",
    "test:a11y": "playwright test --config playwright.config.ts accessibility.spec.ts",
    "test:real-ai": "USE_REAL_AI=true playwright test --config playwright.config.ts",
    "report": "playwright show-report playwright-report",
    "codegen": "playwright codegen http://localhost:3000"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.50.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "wait-on": "^9.0.0"
  }
}
