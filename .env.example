# App
APP_NAME=wayfinder
NODE_ENV=development

# Help menu "Contact developers" link. Overrides the built-in Google Form
# default. Must be prefixed NEXT_PUBLIC_ so it reaches the browser bundle.
NEXT_PUBLIC_CONTACT_FORM_URL=

# Ports
WEB_PORT=3000
API_PORT=3001

# Database (Postgres + pgvector)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wayfinder

# Auth
# AUTH_METHOD options: email-password | pki | pki-and-email-password | google-oauth | other
AUTH_METHOD=email-password
BETTER_AUTH_SECRET=replace-with-32-byte-random-string
BETTER_AUTH_URL=http://localhost:3000
# Encrypts secret-bearing system settings (AI/storage/n8n/auth/email configs)
# at rest with AES-256-GCM. Required on startup. Generate with `openssl rand -hex 32`.
# restart.sh generates one into .env automatically if this is blank.
SETTINGS_ENCRYPTION_KEY=
# Set this before first run — the seed promotes the user with this email to admin
# the first time they register via /admin/register.
ADMIN_SEED_EMAIL=admin@example.com

# Microsoft Entra ID sign-in (ADR-025). Optional fallbacks — the admin-settings
# Authentication card overrides these when an auth_config row exists. When all
# three are set and no DB row overrides them, Entra sign-in is enabled at boot.
# In the Azure app registration, add this redirect URI under the Web platform:
#   ${BETTER_AUTH_URL}/api/auth/callback/microsoft
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# PKI / client-certificate auth (required when AUTH_METHOD includes "pki")
# Comma-separated IPs of reverse proxies trusted to forward cert headers.
# MUST be set and non-empty when PKI auth is enabled — leave blank for email/password.
PKI_TRUSTED_PROXY_IPS=
PKI_SESSION_TTL_HOURS=8

# AI Providers
# AI_DEFAULT_PROVIDER options: anthropic | openai | mistral | bedrock
AI_DEFAULT_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=

# Amazon Bedrock (used when AI_DEFAULT_PROVIDER=bedrock).
# All three values must be set together — leaving any blank falls back to whatever
# is configured in the admin Settings page (or, if nothing is stored there, no creds).
AWS_BEDROCK_REGION=us-east-1
AWS_BEDROCK_ACCESS_KEY_ID=
AWS_BEDROCK_SECRET_ACCESS_KEY=

# Object Storage (MinIO / S3-compatible)
# For local development with docker-compose, the defaults below work out of the box.
# For production on AWS S3: set MINIO_ENDPOINT=s3.amazonaws.com and MINIO_USE_SSL=true.
# For Railway with an external S3-compatible store: point MINIO_ENDPOINT at your provider.
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=wayfinder-documents
MINIO_USE_SSL=false

# Local fallback storage path (used only if MinIO is unavailable in development)
DOCUMENT_STORAGE_PATH=./data

# Observability (Langfuse - stubbed unless both keys are present)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3030

# OpenTelemetry (optional — traces emitted only when endpoint is set)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=wayfinder-api

# Extraction batch engine (ADR-033 §6) — the poller in apps/api that advances
# "Synthesise Information" runs. On by default; set it to false to opt out.
# With it off, a run only progresses while its run screen is open in a browser,
# so a long batch left unattended stalls. Intake limits and the per-run spend
# ceiling are admin settings, not env vars.
EXTRACTION_WORKER_ENABLED=true
EXTRACTION_TICK_MS=5000

# Email notifications (ADR-023)
# NOTIFICATIONS_ENABLED=false still writes outbox rows to app_notification_log
# but skips the send. SMTP_TRANSPORT_MODE options: stream | smtp | oauth2.
#   stream — local sink for dev/tests: messages are built but never delivered.
#   smtp   — generic relay with SMTP AUTH (requires SMTP_HOST/SMTP_USER/SMTP_PASS).
#   oauth2 — Microsoft 365 / Exchange Online via XOAUTH2 (requires the M365_* vars;
#            host defaults to smtp.office365.com:587).
# Leaving SMTP_TRANSPORT_MODE blank falls back to the SMTP settings configured
# in the admin UI. Credentials here are environment-only — never stored in the DB.
NOTIFICATIONS_ENABLED=false
SMTP_TRANSPORT_MODE=stream
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=wayfinder@example.com
M365_TENANT_ID=
M365_CLIENT_ID=
M365_CLIENT_SECRET=
